<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="1200" prefHeight="790"
            stylesheets="@customer-portal.css"
            fx:controller="edu.softwareengineeringproject3773.controller.AccountController"
            styleClass="app-root">
  <top>
    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="header">
      <StackPane minWidth="46" minHeight="46" maxWidth="46" maxHeight="46" styleClass="brand-mark">
        <Label text="UTSA" styleClass="brand-mark-text"/>
      </StackPane>
      <VBox spacing="2">
        <Label text="My Account" styleClass="header-title"/>
        <Label text="Roadrunner Marketplace" styleClass="header-subtitle"/>
      </VBox>
      <Region HBox.hgrow="ALWAYS"/>
      <Button fx:id="backHomeButton" text="Back to Home" styleClass="nav-button"/>
    </HBox>
  </top>

  <center>
    <ScrollPane fitToWidth="true" styleClass="screen-scroll">
      <content>
        <VBox spacing="22" styleClass="page-content">
          <HBox spacing="18" alignment="TOP_LEFT">
            <VBox prefWidth="430" spacing="16" styleClass="card">
              <Label text="Customer Information" styleClass="section-title"/><Label text="First Name" styleClass="field-label"/><TextField fx:id="accountFirstNameField"/><Label text="Last Name" styleClass="field-label"/><TextField fx:id="accountLastNameField"/><Label text="Email" styleClass="field-label"/><TextField fx:id="accountEmailField"/><Button fx:id="updateAccountButton" text="Update Information" styleClass="primary-button"/></VBox><VBox HBox.hgrow="ALWAYS" spacing="12" styleClass="card"><HBox><Label text="Address Book" styleClass="section-title"/><Region HBox.hgrow="ALWAYS"/><Button fx:id="addAddressButton" text="Add Address" styleClass="accent-button"/></HBox><TableView fx:id="addressTableView" prefHeight="360"><columns><TableColumn fx:id="addressTypeColumn" text="Type" prefWidth="110"/><TableColumn fx:id="addressValueColumn" text="Address" prefWidth="390"/><TableColumn fx:id="addressActionsColumn" text="Edit / Delete" prefWidth="170"/></columns></TableView></VBox></HBox></VBox></content></ScrollPane>
  </center>
</BorderPane>
