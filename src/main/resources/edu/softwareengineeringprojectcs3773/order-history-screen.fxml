<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.2"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.softwareengineeringproject3773.controller.OrderHistoryController"
            prefWidth="1200" prefHeight="760"
            stylesheets="@customer-portal.css"
            styleClass="app-root">
  <top>
    <HBox alignment="CENTER_LEFT" spacing="14" styleClass="header">
      <StackPane minWidth="46" minHeight="46" maxWidth="46" maxHeight="46" styleClass="brand-mark">
        <Label text="UTSA" styleClass="brand-mark-text"/>
      </StackPane>
      <VBox spacing="2">
        <Label text="Order History" styleClass="header-title"/>
        <Label text="Roadrunner Marketplace" styleClass="header-subtitle"/>
      </VBox>
      <Region HBox.hgrow="ALWAYS"/>
      <Button fx:id="homeButton" text="Back to Home" styleClass="nav-button"/>
    </HBox>

  </top>

  <center>
    <VBox spacing="18" styleClass="page-content">
      <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar-card">
        <VBox spacing="3">
          <Label text="Your Orders" styleClass="section-title"/>
          <Label text="Select an order to review its purchased items and totals." styleClass="muted-text"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Sort by" styleClass="field-label"/>
        <ComboBox fx:id="sortOrdersComboBox" promptText="Order date or total" prefWidth="230"/>
        <Button fx:id="sortButton" text="Apply Sort" styleClass="primary-button"/>
      </HBox>

      <TableView fx:id="ordersTableView" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
        <TableColumn fx:id="orderNumberColumn" text="Order #" prefWidth="140"/>
        <TableColumn fx:id="orderDateColumn" text="Date" prefWidth="175"/>
        <TableColumn fx:id="orderTotalColumn" text="Total" prefWidth="145"/>
        <TableColumn fx:id="orderStatusColumn" text="Status" prefWidth="165"/>
        <TableColumn fx:id="deliveryColumn" text="Delivery Type" prefWidth="190"/>
        <TableColumn fx:id="viewDetailsColumn" text="Actions" prefWidth="150"/>
      </columns>
      </TableView>
      <HBox alignment="CENTER_LEFT" spacing="8" styleClass="info-strip">
        <Label text="Order details will become available here after checkout is connected to the order database." wrapText="true" styleClass="muted-text"/>
      </HBox>
    </VBox>
  </center>
</BorderPane>
