<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650" prefWidth="900" styleClass="app-root" stylesheets="@customer-portal.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="edu.softwareengineeringproject3773.controller.LoginController">
  <top>
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
      <padding><Insets bottom="16" left="24" right="24" top="16" /></padding>
      <StackPane maxHeight="46" maxWidth="46" minHeight="46" minWidth="46" styleClass="brand-mark"><Label styleClass="brand-mark-text" text="UTSA" /></StackPane>
      <VBox spacing="2"><Label styleClass="page-title" text="Customer Login" /><Label styleClass="page-subtitle" text="Roadrunner Marketplace" /></VBox>
    </HBox>
  </top>
  <center>
    <StackPane>
      <VBox maxWidth="430" spacing="14" styleClass="card">
        <padding><Insets bottom="28" left="28" right="28" top="28" /></padding>
        <Label styleClass="section-title" text="Welcome Back" />
        <Label styleClass="field-label" text="Email or Username" /><TextField fx:id="loginUsernameField" promptText="Enter email or username" />
        <Label styleClass="field-label" text="Password" /><PasswordField fx:id="loginPasswordField" promptText="Enter password" />
        <CheckBox fx:id="rememberMeCheckBox" text="Remember me" />
        <Label fx:id="loginMessageLabel" styleClass="error-label" text="" />
        <Button fx:id="loginButton" maxWidth="Infinity" onAction="#loginAction" styleClass="primary-button" text="Log In" />
        <Button fx:id="openRegisterButton" maxWidth="Infinity" onAction="#createAccountAction" styleClass="secondary-button" text="Create an Account" />
      </VBox>
    </StackPane>
  </center>
</BorderPane>
