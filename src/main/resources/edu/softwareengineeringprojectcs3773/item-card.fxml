<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="edu.softwareengineeringproject3773.controller.ItemCardController"
      prefWidth="250.0"
      minWidth="250.0"
      maxWidth="250.0"
      spacing="10.0"
      styleClass="item-card">

    <padding>
        <Insets top="16.0"
                right="16.0"
                bottom="16.0"
                left="16.0"/>
    </padding>

    <StackPane prefHeight="160.0"
               minHeight="160.0"
               styleClass="item-card-image-container">

        <ImageView fx:id="itemImageView"
                   fitWidth="210.0"
                   fitHeight="150.0"
                   preserveRatio="true"
                   smooth="true"/>

        <Label fx:id="imagePlaceholderLabel"
               text="No Image"
               styleClass="muted-text"/>
    </StackPane>

    <Label fx:id="itemNameLabel"
           text="Item Name"
           wrapText="true"
           maxWidth="220.0"
           styleClass="item-card-title"/>

    <Label fx:id="itemDescriptionLabel"
           text="Item description"
           wrapText="true"
           maxWidth="220.0"
           minHeight="42.0"
           maxHeight="42.0"
           styleClass="item-card-description"/>

    <Label fx:id="itemPriceLabel"
           text=""
           styleClass="item-card-price"/>

    <Label fx:id="availabilityLabel"
           text="In Stock"
           styleClass="availability-label"/>

    <Button fx:id="viewDetailsButton"
            text="View Details"
            maxWidth="1.7976931348623157E308"
            onAction="#handleViewDetails"
            styleClass="accent-button"/>

</VBox>