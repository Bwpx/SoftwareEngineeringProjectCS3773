<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17.0.2" xmlns:fx="http://javafx.com/fxml/1" prefWidth="950" prefHeight="720" stylesheets="@../../../../../../../CustomerPortalScreens/customer-portal.css" styleClass="app-root">
  <top>
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
      <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
      <StackPane minWidth="46" minHeight="46" maxWidth="46" maxHeight="46" styleClass="brand-mark"><Label text="UTSA" styleClass="brand-mark-text"/></StackPane>
      <VBox spacing="2"><Label text="Create Account" styleClass="page-title"/><Label text="Roadrunner Marketplace" styleClass="page-subtitle"/></VBox>
    </HBox>
  </top>
  <center>
    <StackPane>
      <VBox maxWidth="650" spacing="13" styleClass="card">
        <padding><Insets top="26" right="28" bottom="26" left="28"/></padding>
        <Label text="Register for a Customer Account" styleClass="section-title"/>
        <GridPane hgap="12" vgap="10">
          <columnConstraints><ColumnConstraints percentWidth="50"/><ColumnConstraints percentWidth="50"/></columnConstraints>
          <Label text="First Name" styleClass="field-label"/><Label text="Last Name" styleClass="field-label" GridPane.columnIndex="1"/>
          <TextField fx:id="firstNameField" promptText="First name" GridPane.rowIndex="1"/><TextField fx:id="lastNameField" promptText="Last name" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
          <Label text="Email" styleClass="field-label" GridPane.rowIndex="2"/><Label text="Username" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
          <TextField fx:id="emailField" promptText="name@example.com" GridPane.rowIndex="3"/><TextField fx:id="usernameField" promptText="Choose a username" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
          <Label text="Password" styleClass="field-label" GridPane.rowIndex="4"/><Label text="Confirm Password" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
          <PasswordField fx:id="passwordField" promptText="Create password" GridPane.rowIndex="5"/><PasswordField fx:id="confirmPasswordField" promptText="Confirm password" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
        </GridPane>
        <Label fx:id="registerMessageLabel" text="" styleClass="error-label"/>
        <Button fx:id="registerButton" text="Create Account" maxWidth="Infinity" styleClass="accent-button"/>
        <Button fx:id="backToLoginButton" text="Back to Login" maxWidth="Infinity" styleClass="secondary-button"/>
      </VBox>
    </StackPane>
  </center>
</BorderPane>
