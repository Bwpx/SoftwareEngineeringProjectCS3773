<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/17.0.2" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="edu.softwareengineeringproject3773.controller.HomeController"
            prefWidth="1200" prefHeight="760" stylesheets="@customer-portal.css" styleClass="app-root">
  <top>
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
      <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>
      <StackPane minWidth="46" minHeight="46" maxWidth="46" maxHeight="46" styleClass="brand-mark"><Label text="UTSA" styleClass="brand-mark-text"/></StackPane>
      <VBox spacing="2"><Label text="Customer Portal Home" styleClass="page-title"/><Label text="Roadrunner Marketplace" styleClass="page-subtitle"/></VBox>
    </HBox>
  </top>
  <center>
    <VBox spacing="20">
      <padding><Insets top="24" right="28" bottom="28" left="28"/></padding>
      <HBox alignment="CENTER_LEFT"><VBox><Label fx:id="welcomeLabel" text="Welcome, Alex!" styleClass="detail-title"/><Label text="Browse products, manage your cart, and review orders." styleClass="page-subtitle"/></VBox><Region HBox.hgrow="ALWAYS"/><Button fx:id="logoutButton" text="Log Out" styleClass="secondary-button"/></HBox>
      <TilePane hgap="18" vgap="18" prefColumns="4">
        <VBox spacing="10" styleClass="card"><Label text="Browse Items" styleClass="section-title-small"/><Label text="Search products by item name or description." wrapText="true"/><Button fx:id="browseItemsButton" text="Browse" styleClass="primary-button"/></VBox>
        <VBox spacing="10" styleClass="card"><Label text="Shopping Cart" styleClass="section-title-small"/><Label text="View, add, update, or delete cart items." wrapText="true"/><Button fx:id="viewCartButton" text="Open Cart" styleClass="accent-button"/></VBox>
        <VBox spacing="10" styleClass="card"><Label text="Order History" styleClass="section-title-small"/><Label text="Sort past orders by date or total amount." wrapText="true"/><Button fx:id="ordersButton" text="View Orders" styleClass="primary-button"/></VBox>
        <VBox spacing="10" styleClass="card"><Label text="My Account" styleClass="section-title-small"/><Label text="Update customer information and addresses." wrapText="true"/><Button fx:id="accountButton" text="Manage Account" styleClass="primary-button"/></VBox>
      </TilePane>
      <VBox spacing="12" styleClass="card"><Label text="Featured Items" styleClass="section-title"/><TilePane fx:id="featuredItemsPane" hgap="16" vgap="16" prefColumns="3"><Label text="Featured products load here." styleClass="muted-text"/></TilePane></VBox>
    </VBox>
  </center>
</BorderPane>
