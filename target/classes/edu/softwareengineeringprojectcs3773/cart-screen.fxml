<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            prefWidth="1220.0" prefHeight="800.0" stylesheets="@../../../../../../../CustomerPortalScreens/customer-portal.css" styleClass="page">
    <top>
        <HBox styleClass="header">
            <Label text="Shopping Cart" styleClass="header-title" HBox.hgrow="ALWAYS"/>
            <Button fx:id="continueShoppingButton" text="Continue Shopping" styleClass="nav-button"/>
        </HBox>
    </top>
    <center>
        <GridPane hgap="22.0" styleClass="content">
            <columnConstraints>
                <ColumnConstraints percentWidth="68.0"/>
                <ColumnConstraints percentWidth="32.0"/>
            </columnConstraints>
            <VBox spacing="14.0" styleClass="card">
                <Label text="Your Items" styleClass="card-title"/>
                <TableView fx:id="cartTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="cartItemColumn" text="Item" prefWidth="260.0"/>
                        <TableColumn fx:id="cartPriceColumn" text="Price" prefWidth="110.0"/>
                        <TableColumn fx:id="cartQuantityColumn" text="Quantity" prefWidth="120.0"/>
                        <TableColumn fx:id="cartSubtotalColumn" text="Subtotal" prefWidth="130.0"/>
                        <TableColumn fx:id="cartActionColumn" text="Action" prefWidth="120.0"/>
                    </columns>
                </TableView>
                <HBox alignment="CENTER_RIGHT" spacing="10.0">
                    <Button fx:id="updateCartButton" text="Update Cart" styleClass="outline-button"/>
                    <Button fx:id="clearCartButton" text="Clear Cart" styleClass="danger-button"/>
                </HBox>
            </VBox>
            <VBox spacing="14.0" styleClass="card" GridPane.columnIndex="1">
                <Label text="Order Summary" styleClass="card-title"/>
                <VBox spacing="8.0">
                    <HBox styleClass="total-row">
                        <Label text="Subtotal" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="subtotalLabel" text=""/>
                    </HBox>
                    <HBox styleClass="total-row">
                        <Label text="Discount" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="discountLabel" text="-$0.00"/>
                    </HBox>
                    <HBox styleClass="total-row">
                        <Label text="Estimated Tax (8.25%)" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="taxLabel" text=""/>
                    </HBox>
                    <Separator/>
                    <HBox styleClass="total-row">
                        <Label text="Total" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                        <Label fx:id="totalLabel" text="" styleClass="price-label"/>
                    </HBox>
                </VBox>
                <Label text="Discount Code"/>
                <HBox spacing="8.0">
                    <TextField fx:id="discountCodeField" promptText="Enter code" HBox.hgrow="ALWAYS"/>
                    <Button fx:id="applyDiscountButton" text="Apply" styleClass="outline-button"/>
                </HBox>
                <Button fx:id="checkoutButton" text="Proceed to Checkout"
                        maxWidth="1.7976931348623157E308" styleClass="primary-button"/>
                <Label fx:id="cartMessageLabel" text=""/>
            </VBox>
        </GridPane>
    </center>
</BorderPane>
